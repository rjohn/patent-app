// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  supabaseId String?  @unique
  email      String   @unique
  name       String?
  role       UserRole @default(VIEWER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  patents   Patent[]
  notes     PatentNote[]
  uploads   DataUpload[]
  sentNotifications      Notification[]           @relation("NotificationSender")
  notificationRecipients NotificationRecipient[]

  @@map("users")
}

model Invite {
  id        String       @id @default(cuid())
  email     String       @unique
  name      String?
  role      UserRole     @default(VIEWER)
  token     String       @unique @default(cuid())
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime     @default(now())

  @@map("invites")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

// ─── Patent Family ────────────────────────────────────────────────────────────

model PatentFamily {
  id          String   @id @default(cuid())
  name        String
  description String?
  technologyArea String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  patents     Patent[]

  @@map("patent_families")
}

// ─── Patent ───────────────────────────────────────────────────────────────────

model Patent {
  id                String        @id @default(cuid())
  
  // Core identifiers
  applicationNumber String?       @unique
  publicationNumber String?
  epNumber          String?          @unique
  jurisdiction      String?          @default("US")
  patentNumber      String?       @unique
  usptoId           String?       // USPTO internal ID
  
  // Bibliographic data
  title             String
  abstract          String?       @db.Text
  claimsJson        Json?
  status            PatentStatus  @default(PENDING)
  type              PatentType    @default(UTILITY)
  
  // Dates
  filingDate        DateTime?
  publicationDate   DateTime?
  grantDate         DateTime?
  expirationDate    DateTime?
  priorityDate      DateTime?
  
  // Parties
  inventors         String[]      // Array of inventor names
  assignee          String?
  attorney          String?
  
  // Classification
  cpcCodes          String[]      // Cooperative Patent Classification codes
  uspcCodes         String[]      // US Patent Classification codes
  
  // Family relationships
  familyId          String?
  family            PatentFamily? @relation(fields: [familyId], references: [id])
  parentPatentId    String?       // For continuations, divisionals, etc.
  parentPatent      Patent?       @relation("PatentContinuations", fields: [parentPatentId], references: [id])
  childPatents      Patent[]      @relation("PatentContinuations")
  continuationType  ContinuationType?
  
  // Priority claims
  priorityClaims    PriorityClaim[]
  
  // Ownership
  ownerId           String?
  owner             User?         @relation(fields: [ownerId], references: [id])
  
  // Financial
  maintenanceFees   MaintenanceFee[]
  estimatedValue    Float?
  
  // Documents & Notes
  notes             PatentNote[]
  documents         PatentDocument[]
  
  // Source / tracking
  source            PatentSource  @default(PORTFOLIO)

  // Raw data
  rawXmlData        String?       @db.Text
  rawJsonData       Json?

  notifications  Notification[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("patents")
}

enum PatentStatus {
  PENDING
  PUBLISHED
  GRANTED
  ABANDONED
  EXPIRED
  LICENSED
  SOLD
}

enum PatentType {
  UTILITY
  DESIGN
  PLANT
  PROVISIONAL
  PCT
}

enum ContinuationType {
  CONTINUATION
  CONTINUATION_IN_PART
  DIVISIONAL
  REISSUE
  REEXAMINATION
}

enum PatentSource {
  PORTFOLIO       // Manually added to portfolio
  CONTINUATION    // Added from continuity tab — application being tracked
}

// ─── Priority Claims ──────────────────────────────────────────────────────────

model PriorityClaim {
  id            String   @id @default(cuid())
  patentId      String
  patent        Patent   @relation(fields: [patentId], references: [id], onDelete: Cascade)
  country       String
  applicationNumber String
  filingDate    DateTime?
  createdAt     DateTime @default(now())

  @@map("priority_claims")
}

// ─── Maintenance Fees & Deadlines ─────────────────────────────────────────────

model MaintenanceFee {
  id          String      @id @default(cuid())
  patentId    String
  patent      Patent      @relation(fields: [patentId], references: [id], onDelete: Cascade)
  
  feeType     FeeType
  dueDate     DateTime
  amount      Float?
  currency    String      @default("USD")
  status      FeeStatus   @default(UPCOMING)
  paidDate    DateTime?
  paidAmount  Float?
  
  // Grace period
  gracePeriodEnd DateTime?
  
  notes       String?
  reminderSent Boolean   @default(false)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("maintenance_fees")
}

enum FeeType {
  FILING
  PUBLICATION
  GRANT
  MAINTENANCE_3_5
  MAINTENANCE_7_5
  MAINTENANCE_11_5
  ANNUITY
  OTHER
}

enum FeeStatus {
  UPCOMING
  DUE
  OVERDUE
  PAID
  WAIVED
}

// ─── Notes ────────────────────────────────────────────────────────────────────

model PatentNote {
  id        String   @id @default(cuid())
  patentId  String
  patent    Patent   @relation(fields: [patentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("patent_notes")
}

// ─── Documents ────────────────────────────────────────────────────────────────

model PatentDocument {
  id          String       @id @default(cuid())
  patentId    String
  patent      Patent       @relation(fields: [patentId], references: [id], onDelete: Cascade)
  name        String
  type        DocumentType
  url         String       // Supabase Storage URL
  fileSize    Int?
  mimeType    String?
  createdAt   DateTime     @default(now())

  @@map("patent_documents")
}

enum DocumentType {
  APPLICATION
  OFFICE_ACTION
  RESPONSE
  GRANT_CERTIFICATE
  ASSIGNMENT
  LICENSE
  OTHER
}

// ─── Settings (key/value store) ───────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ─── Data Uploads ─────────────────────────────────────────────────────────────

model DataUpload {
  id          String       @id @default(cuid())
  uploadedById String
  uploadedBy  User         @relation(fields: [uploadedById], references: [id])
  fileName    String
  fileType    String
  status      UploadStatus @default(PROCESSING)
  recordsProcessed Int?
  recordsFailed    Int?
  errorLog    String?      @db.Text
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  @@map("data_uploads")
}

enum UploadStatus {
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

// ─── Watchlists ───────────────────────────────────────────────────────────────

model Watchlist {
  id          String           @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  entries     WatchlistEntry[]

  @@map("watchlists")
}

model WatchlistEntry {
  id            String    @id @default(cuid())
  watchlistId   String
  watchlist     Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  // USPTO identifiers
  patentNumber  String?
  appNumber     String?

  // Bibliographic data
  title         String?
  assignee      String?
  inventors     String[]
  filingDate    String?
  grantDate     String?
  expirationDate String?
  status        String?
  abstract      String?   @db.Text
  cpcCodes      String[]
  jurisdiction  String    @default("US")

  // User-added notes
  notes         String?   @db.Text

  // AI-generated portfolio analysis (cached)
  aiSummary     String?   @db.Text
  aiSummaryAt   DateTime?

  addedAt       DateTime  @default(now())
  rawData       Json?

  @@index([watchlistId])
  @@map("watchlist_entries")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String    @id @default(cuid())
  title       String
  message     String    @db.Text
  patentId    String?
  patent      Patent?   @relation(fields: [patentId], references: [id], onDelete: SetNull)
  todoText    String?
  todoDueDate DateTime?
  createdById String?
  createdBy   User?     @relation("NotificationSender", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  recipients  NotificationRecipient[]

  @@map("notifications")
}

model NotificationRecipient {
  id              String       @id @default(cuid())
  notificationId  String
  notification    Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  read            Boolean      @default(false)
  readAt          DateTime?
  todoCompleted   Boolean      @default(false)
  todoCompletedAt DateTime?

  @@unique([notificationId, userId])
  @@map("notification_recipients")
}
